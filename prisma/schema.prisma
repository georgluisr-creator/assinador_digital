generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Receipt {
  id                String   @id @default(uuid()) @db.Uuid
  payerName         String   @map("payer_name")
  payerCpf          String   @map("payer_cpf")
  providerName      String   @map("provider_name")
  providerCpf       String   @map("provider_cpf")
  providerPhone     String   @map("provider_phone")
  serviceDesc       String   @map("service_desc")
  amount            Decimal  @db.Decimal(12, 2)
  serviceDate       DateTime @map("service_date") @db.Date
  signatureBase64   String?  @map("signature_base64") @db.Text
  status            String   @default("pendente")

  @@map("receipts")
}
